{
  "name": "@zkgov/shorts",
  "version": "0.1.0",
  "private": true,
  "description": "Short-form social videos for ZKGov, rendered with Remotion.",
  "scripts": {
    "dev": "remotion studio",
    "build": "remotion render ZkGovQuickstart out/quickstart.mp4",
    "build:wide": "remotion render ZkGovQuickstartWide out/quickstart-wide.mp4",
    "build:square": "remotion render ZkGovQuickstartSquare out/quickstart-square.mp4",
    "build:hq": "remotion render ZkGovQuickstart out/quickstart.mp4 --crf=18",
    "build:wide:hq": "remotion render ZkGovQuickstartWide out/quickstart-wide.mp4 --crf=18",
    "build:all": "npm run build && npm run build:wide && npm run build:square"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@remotion/cli": "^4.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "remotion": "^4.0.0",
    "typescript": "^5.5.4"
  }
}
