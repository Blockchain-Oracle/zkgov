  },
  "devDependencies": {
    "typescript": "^5.5",
    "tsx": "^4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Blockchain-Oracle/zkgov.git"
  },
  "homepage": "https://github.com/Blockchain-Oracle/zkgov",
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "zkgov",
