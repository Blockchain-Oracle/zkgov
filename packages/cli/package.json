{
  "name": "@zkgov/cli",
  "version": "0.0.2",
  "description": "ZKGov CLI — anonymous governance on HashKey Chain with zero-knowledge proofs",
  "type": "module",
  "license": "MIT",
  "bin": {
    "zkgov": "./dist/cli.js"
  },
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    ".": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
